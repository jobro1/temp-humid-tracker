  <step>
    <name>type of message for incident</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Bereken de absolute sprong (Spike detectie)
var delta = Math.abs(value - last_stored_value);

// Definieer harde grenzen (Sticky detectie)
// Je kunt deze ook uit een tabel halen, maar voor nu als voorbeeld:
var max_temp = 40; 
var min_temp = 5;

var is_incident_check = false;
var reden = "";

if (!is_incident){
	// REGEL 1: Is er een te grote sprong?
	if (delta >= threshold_value) {
    	is_incident_check = true;
		if (is_incident_check){
    		reden = "Spike gedetecteerd";
		}
	} 

	else if (value >= max_temp || value &lt;= min_temp) {
	    is_incident_check = true;
		if (is_incident_check){
	    	reden = "Buiten veilige zone";
		}
	}
}
</jsScript_script>
      </jsScript>
    </jsScripts>
