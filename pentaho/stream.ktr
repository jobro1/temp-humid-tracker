    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Maak een nieuw veld aan: final_value
var final_value;

if (clean_value == null) {
    // Als de huidige meting corrupt was, gebruik de vorige
    final_value = last_stored_value;
	reden = "message was unavailable"
	is_incident = true
} else {
    // Als de meting goed is, gebruik de huidige
    final_value = clean_value;
}

// Optioneel: Loggen naar de console als er een correctie plaatsvindt
if (clean_value == null &amp;&amp; last_stored_value!= null) {
    writeToLog("m", "Correctie uitgevoerd: 'unavailable' vervangen door " + last_stored_value);
}</jsScript_script>
      </jsScript>
    </jsScripts>
